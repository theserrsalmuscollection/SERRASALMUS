# SERRA ORGIN Environment Configuration

# Application Settings
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Server Settings
HOST=0.0.0.0
PORT=8000
WEBSOCKET_PORT=8001

# Database Settings
DATABASE_URL=sqlite:///./data/serra_orgin.db
REDIS_URL=redis://localhost:6379

# AI Model Settings (Optional - uses local models by default)
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
DEFAULT_MODEL=gpt-3.5-turbo
MODEL_TEMPERATURE=0.7
MAX_TOKENS=4000

# Local Model Settings
LOCAL_MODEL_PATH=./models
USE_LOCAL_MODELS=true

# Agent Settings
MAX_AGENTS=10
AGENT_TIMEOUT=300
AGENT_MEMORY_SIZE=1000

# Scraper Settings
SCRAPER_USER_AGENT=SERRA ORGIN Web Scraper 1.0
SCRAPER_DELAY_MIN=1.0
SCRAPER_DELAY_MAX=5.0
MAX_CONCURRENT_SCRAPES=5

# MCP Settings
MCP_SERVER_PORT=9000
MCP_ENABLED_TOOLS=github,filesystem,web_search,code_execution,database,docker

# RAG Settings
EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTOR_DB_PATH=./data/vectordb
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Security Settings
SECRET_KEY=change-this-in-production
JWT_EXPIRY_HOURS=24

# GitHub Integration (Optional)
GITHUB_TOKEN=your_github_token_here
DEFAULT_GITHUB_USER=your_username

# Docker Settings
DOCKER_SOCKET=unix://var/run/docker.sock
DOCKER_REGISTRY=

# Deployment Settings
DEPLOYMENT_ENVIRONMENTS=development,staging,production
AUTO_DEPLOY=false

# UI Settings
WEB_UI_PORT=3000
UI_THEME=dark

# Contact Information
ADMIN_EMAIL=polerbear1973@gmail.com
ORGANIZATION_EMAIL=theserralmuscollectionllc@gmail.com
